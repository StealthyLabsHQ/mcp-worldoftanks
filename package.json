{
  "name": "wot-mcp-server",
  "version": "2.0.0",
  "description": "MCP Server exposant les donnees World of Tanks pour Claude Code et Claude Desktop",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "auth": "tsx src/auth/openid.ts",
    "start": "node dist/index.js",
    "install:desktop": "bash setup/install-desktop.sh",
    "install:desktop:win": "powershell -File setup/install-desktop.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0"
  }
}
